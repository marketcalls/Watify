# Watify backend configuration.
# Copy to backend/.env and adjust. NEVER commit backend/.env (gitignored).

# Server
WATIFY_HOST=127.0.0.1
WATIFY_PORT=8000
WATIFY_CORS_ORIGIN=http://localhost:3000

# Storage
WATIFY_APP_DB=app.db
WATIFY_WHATSAPP_DB=whatsapp.db

# Sending defaults
WATIFY_MIN_DELAY_S=3
WATIFY_MAX_DELAY_S=30
WATIFY_GROUP_MAX_CONTACTS=20

# Rate limits (TKT-0015). slowapi syntax: "N/period", e.g. "5/minute",
# "100/hour". 429 responses use the flat envelope from TKT-0001 and
# include Retry-After. These are the HARD caps -- the dashboard
# SoftCapBanner is just a UI hint.
WATIFY_RATE_LIMIT_TEST_SELF=15/minute
WATIFY_RATE_LIMIT_TEST_TO=10/minute
WATIFY_RATE_LIMIT_SEND=5/minute

# Logging
WATIFY_LOG_LEVEL=INFO
WATIFY_LOG_FILE=../docs/.support/logs/backend.log

# Session encryption (TKT-0011). When set, the WaSingleton will store
# the wars session bytes as a Fernet-encrypted blob in app.db instead
# of plaintext on disk. Generate a key with:
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave unset to keep the legacy file-backed mode (backend/whatsapp.db).
# TKT-0011b will auto-migrate any existing whatsapp.db once a key is set.
# WATIFY_SESSION_ENCRYPTION_KEY=replace-with-44-char-fernet-key

# Owner phone display (TKT-0005). Optional. When set, the Ready panel
# on /connect shows "Linked as +CC XX..." using this number. Leave
# unset to let the backend learn it passively from the first echo of
# an outgoing WhatsApp message (an `is_from_me` event from wars).
# WATIFY_OWNER_PHONE=+91 9876543210
